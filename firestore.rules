rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // CATCH-ALL DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin lookup supports both hardcoded email (bootstrap) and administrative collection
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "management250197@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // VALIDATION BLUEPRINTS
    // ===============================================================

    function isValidDossier(data) {
      return data.keys().hasAll(['numeroBL', 'statut']) &&
             data.numeroBL is string && data.numeroBL.size() > 0 && data.numeroBL.size() < 100 &&
             data.statut in ['en_cours', 'cloture'] &&
             (!('nbConteneurs' in data) || (data.nbConteneurs is number)) &&
             (!('prixContrat' in data) || (data.prixContrat is number));
    }

    function isValidConteneur(data) {
      return data.keys().hasAll(['numero', 'dossierId']) &&
             data.numero is string && data.numero.size() > 0 &&
             data.dossierId is string && isValidId(data.dossierId);
    }

    function isValidChargement(data) {
      return data.keys().hasAll(['dossierId', 'conteneurId', 'typeTransporteur', 'statutPaiement']) &&
             data.dossierId is string && isValidId(data.dossierId) &&
             data.conteneurId is string && isValidId(data.conteneurId) &&
             data.typeTransporteur in ['interne', 'externe'] &&
             data.statutPaiement in ['non_paye', 'paye'] &&
             (!('avance' in data) || (data.avance is number)) &&
             (!('prixTotal' in data) || (data.prixTotal is number)) &&
             (!('solde' in data) || (data.solde is number));
    }

    function isValidPartenaire(data) {
      return data.keys().hasAll(['nom']) &&
             data.nom is string && data.nom.size() > 0;
    }

    function isValidCamion(data) {
      return data.keys().hasAll(['numero', 'statut']) &&
             data.numero is string && data.numero.size() > 0 &&
             data.statut in ['actif', 'inactif'];
    }

    // ===============================================================
    // RESOURCE MATCHES
    // ===============================================================

    match /settings/global {
      allow read: if true; // Publicly readable settings for initialization
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /dossiers/{dossierId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDossier(incoming());
      allow update: if isSignedIn() && (isAdmin() || isValidDossier(incoming()));
      allow delete: if isAdmin();
    }

    match /conteneurs/{conteneurId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn() && isValidConteneur(incoming());
       allow update: if isSignedIn() && (isAdmin() || isValidConteneur(incoming()));
       allow delete: if isAdmin();
    }

    match /chargements/{chargementId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn() && isValidChargement(incoming());
       allow update: if isSignedIn() && (isAdmin() || isValidChargement(incoming()));
       allow delete: if isAdmin();
    }

    match /camions/{camionId} {
       allow read: if isSignedIn();
       allow create: if isAdmin();
       allow update: if isAdmin();
       allow delete: if isAdmin();
    }

    match /partenaires/{partenaireId} {
       allow read: if isSignedIn();
       allow create: if isAdmin();
       allow update: if isAdmin();
       allow delete: if isAdmin();
    }

    // System-level admins collection for RBAC
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System-only managed
    }
  }
}
